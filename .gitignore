# Xcode project is generated by XcodeGen — never commit it
*.xcodeproj
*.xcworkspace

# Xcode / build artifacts
DerivedData/
build/
*.xcresult
xcuserdata/

# Swift Package Manager
.build/
.swiftpm/

# Compiled Core ML artifacts (ship via release pipeline, not git)
*.mlmodelc

# macOS
.DS_Store

# Local env / secrets (dev tooling only — the app itself has none by invariant)
.env
*.env
*.p8

# Local Claude Code overrides
.claude/settings.local.json
